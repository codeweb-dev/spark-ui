# Public configuration (safe to expose to the browser).
# Canonical site origin used for metadata, sitemap, and install commands.
NEXT_PUBLIC_APP_URL=https://spark-ui-olive.vercel.app

# Backend features (GitHub login + favorites) are optional — the site runs
# UI-only without them, so contributors don't need a Supabase project.
# Set to true AND fill in the Supabase values below to enable them.
NEXT_PUBLIC_BACKEND=false

# Supabase project values — fill in from the Supabase dashboard.
# Never commit production values, the service-role key, or the database password.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
